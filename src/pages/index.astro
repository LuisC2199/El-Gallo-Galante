---
import Shell from "../layouts/Shell.astro";
import { getCollection, getEntry, type CollectionEntry } from "astro:content";

const issues: CollectionEntry<"issues">[] = await getCollection("issues");

const latestIssue: CollectionEntry<"issues"> | undefined = issues
  .slice()
  .sort(
    (a: CollectionEntry<"issues">, b: CollectionEntry<"issues">) =>
      b.data.date.valueOf() - a.data.date.valueOf()
  )[0];

const posts: CollectionEntry<"posts">[] = await getCollection("posts");

// Get featured posts from featuredPostSlugs in order
const featuredWorks: CollectionEntry<"posts">[] = latestIssue?.data.featuredPostSlugs
  ? await Promise.all(
      latestIssue.data.featuredPostSlugs.map(async (slug: string) => {
        const post = posts.find((p) => p.slug === slug);
        if (!post) throw new Error(`Featured post not found: ${slug}`);
        return post;
      })
    )
  : [];

// Get 5 latest posts for carousel
const issueSlug = latestIssue?.id.replace(/\.md$/, '');
const latestPosts: CollectionEntry<"posts">[] = latestIssue
  ? posts
      .filter((p: CollectionEntry<"posts">) => p.data.issue === issueSlug)
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
      .slice(0, 5)
  : [];

const latestPostsWithAuthors: { post: CollectionEntry<"posts">; author: CollectionEntry<"authors"> }[] =
  await Promise.all(
    latestPosts.map(async (post: CollectionEntry<"posts">) => {
      const author = await getEntry(post.data.author);
      if (!author) throw new Error(`Author not found for post: ${post.slug}`);
      return { post, author };
    })
  );

const featuredWorksWithAuthors: { post: CollectionEntry<"posts">; author: CollectionEntry<"authors"> }[] =
  await Promise.all(
    featuredWorks.map(async (post: CollectionEntry<"posts">) => {
      const author = await getEntry(post.data.author);
      if (!author) throw new Error(`Author not found for post: ${post.slug}`);
      return { post, author };
    })
  );

const formatDate = (date: Date, issueId?: string): string => {
  // Special case for the first issue (2018-2025)
  if (issueId && (issueId === 'ano-1-numero-0.md' || issueId === 'ano-1-numero-0')) {
    return '2018–2025';
  }
  return new Intl.DateTimeFormat("es-MX", {
    year: "numeric",
    month: "long",
  }).format(date);
};
---

<Shell title="El Gallo Galante">
  {latestIssue ? (
    <>
      {/* Full-Screen Hero Section */}
      <section class="flex items-center overflow-x-hidden justify-center px-6 pt-10 pb-8 md:py-20 md:min-h-screen hero-fade-in">
        <div class="max-w-5xl text-center">
          <h1 class="display-serif text-4xl md:text-8xl lg:text-9xl font-bold tracking-tight text-stone-900 mb-6 md:mb-8">
            El Gallo Galante
          </h1>
          
          <p class="text-xs md:text-sm uppercase tracking-[0.3em] md:tracking-[0.4em] text-stone-500 mb-8 md:mb-12 font-light">
            La palabra debe hendir el mundo
          </p>

          {/* Carousel with latest 5 posts */}
          <div class="mt-8 md:mt-12 mb-8 md:mb-16">
            {/* Label with scroll hint */}
            <div class="flex items-center justify-center gap-2 md:gap-3 mb-4 md:mb-6">
              <svg class="w-3 h-3 md:w-4 md:h-4 text-stone-400 animate-bounce-horizontal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
              </svg>
              <p class="text-[10px] md:text-xs uppercase tracking-[0.3em] md:tracking-[0.4em] text-stone-400 font-light">
                Entradas recientes
              </p>
              <svg class="w-3 h-3 md:w-4 md:h-4 text-stone-400 animate-bounce-horizontal-reverse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
            <div 
              class="carousel-container overflow-x-scroll overflow-y-hidden pb-6 md:pb-8"
              style="-webkit-overflow-scrolling: touch;"
            >
              <div class="carousel-track inline-flex gap-3 md:gap-4">
                <div class="flex-shrink-0 w-6"></div>
                {latestPostsWithAuthors.map(({ post, author }) => (
                  <a
                    href={`/posts/${post.slug}`}
                    class="carousel-item flex-shrink-0 w-[240px] md:w-[320px]"
                  >
                    <div class="relative overflow-hidden rounded-lg h-[320px] md:h-[400px] shadow-lg hover:shadow-2xl transition-all duration-300">
                      {post.data.coverImage && (
                        <img
                          src={post.data.coverImage}
                          alt={post.data.title}
                          class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
                          loading="lazy"
                        />
                      )}
                      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10"></div>
                      <div class="absolute bottom-0 left-0 right-0 p-4 md:p-6 text-white">
                        <div class="text-[9px] md:text-[10px] uppercase tracking-[0.3em] md:tracking-[0.35em] text-white/70 mb-1 md:mb-2">
                          {post.data.category}
                        </div>
                        <h3 class="display-serif text-lg md:text-xl font-bold leading-tight mb-1 md:mb-2 group-hover:opacity-90 transition-opacity">
                          {post.data.title}
                        </h3>
                        <p class="text-xs md:text-sm text-white/80">{author.data.name}</p>
                      </div>
                    </div>
                  </a>
                ))}
                <div class="flex-shrink-0 w-6"></div>
              </div>
            </div>
          </div>

          <div class="mt-0 md:mt-8">
            <a
              href="#featured"
              class="inline-block text-stone-400 hover:text-stone-600 transition-colors animate-bounce-slow"
            >
              <svg class="w-6 h-6 md:w-8 md:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
              </svg>
            </a>
          </div>
        </div>
      </section>

      {/* Featured Works Section */}
      <section id="featured" class="py-6 md:py-2 px-6">
        <div class="max-w-7xl mx-auto">
          <h2 class="text-xs uppercase tracking-[0.4em] text-stone-400 mb-16 text-center font-light">
            Lecturas destacadas
          </h2>

          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-10">
            {featuredWorksWithAuthors.map(({ post, author }) => (
              <a 
                href={`/posts/${post.slug}`}
                class="group block featured-card overflow-hidden rounded-lg shadow-lg hover:shadow-2xl transition-all duration-300"
              >
                {/* Cover Image */}
                {post.data.coverImage && (
                  <div class="relative h-[300px] md:h-[350px] overflow-hidden">
                    <img
                      src={post.data.coverImage}
                      alt={post.data.title}
                      class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                    
                    {/* Category Badge */}
                    <div class="absolute top-4 left-4 text-[10px] uppercase tracking-[0.35em] text-white bg-black/30 backdrop-blur-sm px-3 py-1 font-light">
                      {post.data.category}
                    </div>
                  </div>
                )}

                {/* Content */}
                <div class="p-6 space-y-4 bg-white">
                  {/* Title */}
                  <h3 class="display-serif text-2xl md:text-3xl font-bold leading-tight text-stone-900 group-hover:text-stone-600 transition-colors">
                    {post.data.title}
                  </h3>

                  {/* Author */}
                  <p class="text-sm tracking-wide text-stone-600">
                    {author.data.name}
                  </p>

                  {/* Excerpt */}
                  {post.data.excerpt && (
                    <p class="serif text-base leading-relaxed text-stone-600 line-clamp-3">
                      {post.data.excerpt}
                    </p>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      {/* Current Issue Section */}
      <section class="py-24 md:py-32 px-6 bg-stone-50">
        <div class="max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
            {/* Cover Image */}
            {latestIssue.data.coverImage && (
              <div class="order-2 lg:order-1">
                <img
                  src={latestIssue.data.coverImage}
                  alt={latestIssue.data.title}
                  class="w-full h-auto shadow-2xl grayscale hover:grayscale-0 transition-all duration-700"
                />
              </div>
            )}

            {/* Issue Info */}
            <div class="order-1 lg:order-2 space-y-8">
              <div>
                <p class="text-xs uppercase tracking-[0.4em] text-stone-400 mb-4 font-light">
                  Número actual
                </p>
                <h2 class="display-serif text-5xl md:text-6xl font-bold leading-tight text-stone-900 mb-6">
                  {latestIssue.data.title}
                </h2>
                <p class="text-sm tracking-wide text-stone-500 mb-8">
                  {formatDate(latestIssue.data.date, latestIssue.id)} · {latestIssue.data.number}
                </p>
              </div>

              <a
                href={`/numeros/${latestIssue.id.replace(/\.md$/, '')}`}
                class="inline-block px-8 py-4 bg-stone-900 text-white text-xs uppercase tracking-[0.3em] hover:bg-stone-800 transition-colors font-light"
              >
                Leer número
              </a>
            </div>
          </div>
        </div>
      </section>

      {/* Preamble Section */}
      <section class="py-24 md:py-32 px-6">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="display-serif text-4xl md:text-5xl font-bold mb-16 text-stone-900">
            Preámbulo
          </h2>

          <div class="serif text-lg md:text-xl leading-loose text-stone-700 space-y-8 text-left">
            <p>
              <strong class="font-semibold text-stone-900">El Gallo Galante</strong> es aquel que escupe sin escrúpulos, escupitajo siempre directo, pero sin perder el temple. Cuando se atora el gallo hay que sacarlo, dejarlo cacarear, que se suelten los picotazos, pero siempre con plena conciencia de lo que suscita.
            </p>

            <p>
              <strong class="font-semibold text-stone-900">El Gallo Galante</strong> no significa lucha en el sentido más ideológico, sería una traición a lo que pretende, sino que lucha desde su frente; contamos con una única arma: la palabra. Diría Revueltas que ésta «debe hendir el mundo» y así lo pretendemos.
            </p>

            <p>
              Partiendo desde lo literario—pues al cabo de eso venimos—las plumas de este Gallo escribirán sobre diversos temas de la cultura y las artes. Cada una de ellas es de distinto matiz y gusto, lo que nos convierte en un solícito Gallo polícromo, atento a las novedades y extrañezas de nuestro tiempo.
            </p>

            <p>
              <strong class="font-semibold text-stone-900">El Gallo Galante</strong> se complace en anunciarse a sí mismo, y en presentar este proyecto de estudiantes que en sus esporádicos tiempos libres buscan acercar la cultura, a través de la palabra, a todo aquel a quien su curiosidad anime a leer estas páginas.
            </p>
            <p>Hasta aquí escribimos, lector,</p>
            <div class="my-6 py-8 italic text-stone-600 space-y-3">
              
              <p>
                Y adiós, que esto no es más de<br />
                darte la muestra del paño;<br />
                si no te agrada la pieza,<br />
                no desenvuelvas el fardo. <sup class="text-xs non-italic">[1]</sup>
              </p>
            </div>

            <p class="text-right font-semibold text-stone-900 not-italic">
              Los editores
            </p>

            <p class="text-sm text-stone-500 pt-8 mt-8 text-left border-t border-stone-100 not-italic">
              [1] Sor Juana Inés de la Cruz, 1690.
            </p>
          </div>
        </div>
      </section>

      {/* All Issues CTA */}
      <section class="py-20 px-6 text-center border-t border-stone-100">
        <a
          href="/numeros"
          class="inline-block text-xs uppercase tracking-[0.4em] text-stone-400 hover:text-stone-900 transition-colors font-light"
        >
          Ver todos los números →
        </a>
      </section>
    </>
  ) : (
    <div class="min-h-screen flex items-center justify-center px-6">
      <div class="text-center">
        <h1 class="display-serif text-6xl md:text-8xl font-bold text-stone-900 mb-6">
          El Gallo Galante
        </h1>
        <p class="text-sm uppercase tracking-[0.4em] text-stone-400 font-light">
          Próximamente
        </p>
      </div>
    </div>
  )}

  <style>
    .hero-fade-in {
      animation: fadeIn 1.2s ease-out;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-bounce-slow {
      animation: bounce 3s infinite;
    }

    @keyframes bounce {
      0%, 100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-10px);
      }
    }

    .animate-bounce-horizontal {
      animation: bounceHorizontal 2s infinite;
    }

    .animate-bounce-horizontal-reverse {
      animation: bounceHorizontalReverse 2s infinite;
    }

    @keyframes bounceHorizontal {
      0%, 100% {
        transform: translateX(0);
        opacity: 0.6;
      }
      50% {
        transform: translateX(-8px);
        opacity: 1;
      }
    }

    @keyframes bounceHorizontalReverse {
      0%, 100% {
        transform: translateX(0);
        opacity: 0.6;
      }
      50% {
        transform: translateX(8px);
        opacity: 1;
      }
    }

    .featured-card {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .featured-card:hover {
      transform: translateY(-4px);
    }

    .line-clamp-3 {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* Carousel styles for iOS Safari compatibility */
    .carousel-container {
      scrollbar-width: none;
      -ms-overflow-style: none;
      scroll-behavior: auto;
      position: relative;
    }
    
    .carousel-container::-webkit-scrollbar {
      display: none;
      width: 0;
      height: 0;
    }

    .carousel-track {
      /* Force horizontal layout and prevent wrapping */
      white-space: nowrap;
      display: inline-flex;
    }

    .carousel-item {
      /* Prevent any shrinking on iOS */
      flex: 0 0 auto;
      display: inline-block;
      white-space: normal;
    }

    /* Smooth scroll behavior */
    html {
      scroll-behavior: smooth;
    }
  </style>
</Shell>
