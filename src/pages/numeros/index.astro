---
import Shell from "../../layouts/Shell.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const issues: CollectionEntry<"issues">[] = await getCollection("issues");

const sortedIssues: CollectionEntry<"issues">[] = issues
  .slice()
  .sort(
    (a: CollectionEntry<"issues">, b: CollectionEntry<"issues">) =>
      b.data.date.valueOf() - a.data.date.valueOf()
  );

const formatDate = (date: Date, issueId?: string): string => {
  // Special case for the first issue (2018-2025)
  if (issueId === 'ano-1-numero-0.md' || issueId === 'ano-1-numero-0') {
    return '2018–2025';
  }
  return new Intl.DateTimeFormat("es-MX", {
    year: "numeric",
    month: "long",
  }).format(date);
};
---

<Shell title="Números · El Gallo Galante" description="Archivo completo de números de la revista.">
  <div class="max-w-6xl mx-auto px-6">
    <header class="max-w-3xl mx-auto mb-16 md:mb-24 text-center">
      <p class="text-[10px] tracking-[0.3em] uppercase font-semibold text-stone-500 inline-block">
        Archivo
      </p>

      <h1 class="display-serif text-4xl md:text-7xl font-bold leading-tight mt-6">
        Números
      </h1>

      <div class="mt-10 text-[10px] uppercase tracking-[0.3em] text-stone-400">
        {sortedIssues.length} {sortedIssues.length === 1 ? 'número' : 'números'}
      </div>
    </header>

    <section class="space-y-8 max-w-4xl mx-auto">
      {sortedIssues.map((issue: CollectionEntry<"issues">) => (
        <a
          href={`/numeros/${issue.id.replace(/\.md$/, '')}`}
          class="group block relative overflow-hidden rounded-xl h-[350px] md:h-[420px] hover:shadow-2xl transition-all duration-500"
        >
          {/* Background Cover Image */}
          {issue.data.coverImage && (
            <img
              src={issue.data.coverImage}
              alt={issue.data.title}
              class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
              loading="lazy"
            />
          )}

          {/* Overlay for text readability */}
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/20"></div>

          {/* Content positioned at bottom */}
          <div class="absolute bottom-0 left-0 right-0 p-8 md:p-12 text-white">
            {/* Label */}
            <p class="text-[10px] tracking-[0.3em] uppercase font-bold text-white/90 bg-white/20 backdrop-blur-sm inline-block px-3 py-1 mb-4">
              Número {issue.data.number || ''}
            </p>

            {/* Title */}
            <h2 class="display-serif text-3xl md:text-5xl font-bold leading-tight text-white group-hover:opacity-90 transition-opacity">
              {issue.data.title}
            </h2>

            {/* Date */}
            <p class="mt-4 text-sm md:text-base text-white/80 tracking-wide serif">
              {formatDate(issue.data.date, issue.id)}
            </p>

            {/* Description */}
            {issue.data.description && (
              <p class="mt-4 serif text-base md:text-lg text-white/85 leading-relaxed max-w-3xl">
                {issue.data.description}
              </p>
            )}
          </div>

          {/* Fallback if no cover image */}
          {!issue.data.coverImage && (
            <div class="absolute inset-0 bg-gradient-to-br from-stone-800 to-stone-900"></div>
          )}
        </a>
      ))}
    </section>

    {sortedIssues.length === 0 && (
      <div class="max-w-2xl mx-auto text-center py-20">
        <p class="serif text-stone-500 italic text-lg">Aún no hay números publicadas.</p>
      </div>
    )}
  </div>
</Shell>
