---
export const prerender = false;
import AdminShell from "../../components/admin/AdminShell";
import "../../styles/global.css";

// Editor identity is set by middleware after JWT verification
const editor = (Astro.locals as any).editor ?? null;
const editorJson = editor
  ? JSON.stringify({ email: editor.email, name: editor.name })
  : "null";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin · El Gallo Galante</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <script define:vars={{ editorJson }}>
      window.__EDITOR__ = JSON.parse(editorJson);
    </script>
  </head>
  <body class="m-0 font-sans">
    <AdminShell client:load />
  </body>
</html>