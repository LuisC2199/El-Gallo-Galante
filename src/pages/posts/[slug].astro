---
import Shell from "../../layouts/Shell.astro";
import ArticleHeader from "../../components/ArticleHeader.astro";
import { getEntry, getCollection, type CollectionEntry } from "astro:content";
import AuthorAvatar from "../../components/AuthorAvatar.astro";

export async function getStaticPaths() {
  const posts: CollectionEntry<"posts">[] = await getCollection("posts",
    (p: CollectionEntry<"posts">) => (p.data.status ?? "published") === "published",
  );
  return posts.map((post: CollectionEntry<"posts">) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<"posts"> };
const isPoetry = post.data.category === "Poesía";
const pres = post.data.presentacion;
const dropCapMode = pres.dropCapMode ?? "auto";
const author = await getEntry(post.data.author);
const { Content: PostContent } = await post.render();
const { Content: AuthorContent } = await author.render();
const traductor = post.data.traductor ? await getEntry(post.data.traductor) : null;
const ogImage = post.data.coverImage ?? post.data.featuredImage;
---

<Shell title={`${post.data.title} · El Gallo Galante`} description={post.data.excerpt} ogImage={ogImage} ogType="article">
  <article class="max-w-screen-xl mx-auto px-6">
    <ArticleHeader post={post} author={author} />

    <div class="max-w-2xl mx-auto">
      {pres.metaEpistolar && (
        <p class="meta-epistolar">{pres.metaEpistolar}</p>
      )}

      {pres.dedicatoria && (
        <p class="dedicatoria">{pres.dedicatoria}</p>
      )}

      {pres.epigrafe && (
        <blockquote class="epigrafe">
          <p>{pres.epigrafe}</p>
          {pres.epigrafeAutor && <cite>{pres.epigrafeAutor}</cite>}
        </blockquote>
      )}

      <div
        class:list={[
          "entry-content serif text-stone-800",
          dropCapMode === "auto" && "drop-cap",
          // Poetry: `whitespace-pre-line` preserves verse line-breaks (structurally
          // necessary), `overflow-x-auto` prevents layout breakage for long lines,
          // `poetry` provides stanza margin via the .poetry CSS rules.
          // Font-size, line-height, and paragraph spacing live in global.css
          // (.entry-content rules) so the page wrapper stays formatting-neutral.
          isPoetry && "whitespace-pre-line overflow-x-auto poetry",
        ]}
      >
        <PostContent />
      </div>

      {pres.firma && (
        <p class="poem-signature">{pres.firma}</p>
      )}

      <footer class="mt-32 md:mt-40 pt-16 border-t border-stone-100 flex flex-col items-center gap-8">
        <div class="flex flex-col items-center gap-4 text-center max-w-sm">
          <AuthorAvatar
            name={author.data.name}
            photo={author.data.photo}
            size="md"
            class="author-photo"
          />
          <h4 class="text-xs uppercase tracking-widest font-bold">{author.data.gender === false ? "Sobre la autora" : "Sobre el autor"}</h4>
          <p class="serif text-stone-500 italic">
            <AuthorContent />
          </p>
          <a
            href={`/autor/${author.slug}`}
            class="text-[10px] uppercase font-bold tracking-widest hover:text-stone-400 transition-colors"
          >
            Ver todos los textos de {author.data.name}
          </a>
          {traductor && (
            <p class="text-sm text-stone-400 mt-2">
              Traducción: <a class="underline underline-offset-4 hover:text-stone-800" href={`/autor/${traductor.slug}`}>{traductor.data.name}</a>
            </p>
          )}
        </div>
      </footer>
    </div>
  </article>
</Shell>
