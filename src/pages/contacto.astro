---
import { getCollection } from "astro:content";
import { marked } from "marked";
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Shell from "../layouts/Shell.astro";

type BaseItem = {
  title?: string;
  text: string;
};

const entries = await getCollection("contact" as any);
const contact = entries[0];

if (!contact) {
  throw new Error("Missing contact page content at src/content/contact/contact.md");
}

const data = (contact as any).data;
const title = String(data.title ?? "Contáctanos");
const description = String(data.description ?? "Una revista es también una conversación.");
const heading = String(data.heading ?? "Bases de publicación");
const intro = String(data.intro ?? "");
const bases: BaseItem[] = Array.isArray(data.bases) ? data.bases : [];
const conditionsHeading = String(data.conditionsHeading ?? "Condiciones de publicación");
const conditions: string[] = Array.isArray(data.conditions) ? data.conditions : [];
const note = typeof data.note === "string" ? data.note : "";

function renderInline(value: unknown): string {
  return marked.parseInline(String(value ?? ""), { async: false }) as string;
}
---

<Shell title={`${title} · El Gallo Galante`} description={description}>
  <Layout title={`${title} · El Gallo Galante`}>
    <Navigation />

    <!-- Wider container -->
    <main class="max-w-7xl mx-auto px-6 md:px-10 pb-16 md:pb-24">
      <!-- Header: less boxed -->
      <header class="text-center mb-16 md:mb-24 pt-6">

        <h1 class="display-serif text-4xl md:text-7xl font-bold leading-tight mt-6 text-stone-900">
          {title}
        </h1>

      </header>

      <!-- Body: left fixed width, right fluid -->
      <div class="grid grid-cols-1 md:grid-cols-[320px_1fr] gap-10 md:gap-16 items-start">

        <!-- Left: pushed visually left by wider container -->
        <aside class="space-y-10 md:sticky md:top-28">
          <div class="border border-stone-100 bg-white/60 p-8">
            <h2 class="text-[10px] uppercase tracking-[0.35em] text-stone-400 font-semibold">
              Correo electrónico
            </h2>

            <a
              href="mailto:contacto@elgallogalante.com"
              class="mt-5 flex items-center gap-3 text-stone-800 hover:text-stone-500 transition-colors"
            >
              <svg class="w-4 h-4 opacity-70" viewBox="0 0 24 24" fill="none">
                <path d="M4 7h16v10H4V7Z" stroke="currentColor" stroke-width="2"/>
                <path d="m4 7 8 6 8-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
              <span class="serif text-lg">elgallogalante@gmail.com</span>
            </a>

          </div>

          <div class="border border-stone-100 bg-white/60 p-8">
            <h2 class="text-[10px] uppercase tracking-[0.35em] text-stone-400 font-semibold">
              Redes sociales
            </h2>

            <div class="mt-6 flex flex-col gap-4">
              <a
                class="flex items-center gap-3 text-stone-700 hover:text-stone-900 transition-colors"
                href="https://www.instagram.com/elgallogalante"
                target="_blank"
                rel="noreferrer"
              >
                <svg class="w-4 h-4 opacity-70" viewBox="0 0 24 24" fill="none">
                  <rect x="7" y="7" width="10" height="10" rx="3" stroke="currentColor" stroke-width="2"/>
                  <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
                </svg>
                <span class="text-sm tracking-wide">Instagram</span>
              </a>

              <a
                class="flex items-center gap-3 text-stone-700 hover:text-stone-900 transition-colors"
                href="https://x.com/elgallogalante"
                target="_blank"
                rel="noreferrer"
              >
                <svg class="w-4 h-4 opacity-70" viewBox="0 0 24 24" fill="none">
                  <path d="M6 18L18 6M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span class="text-sm tracking-wide">X (Twitter)</span>
              </a>
              <a
                class="flex items-center gap-3 text-stone-700 hover:text-stone-900 transition-colors"
                href="https://www.facebook.com/ElGalloGalante"
                target="_blank"
                rel="noreferrer"
              >
                <svg class="w-4 h-4 opacity-70" viewBox="0 0 24 24" fill="none">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="text-sm tracking-wide">Facebook</span>
              </a>
            </div>
          </div>
        </aside>

        <!-- Right: now much wider -->
        <section class="space-y-8 max-w-none">
          <div class="max-w-4xl">
            <div class="mb-8">
              <h2 class="display-serif text-3xl md:text-4xl font-bold text-stone-900 mb-4">
                {heading}
              </h2>
              <p class="serif text-lg text-stone-600 leading-relaxed">
                {intro}
              </p>
            </div>

            <div class="space-y-10">
              <div class="border-l-2 border-stone-200 pl-8">
                <ol class="space-y-10">
                  {bases.map((base, index) => (
                    <li class="relative">
                      <span class="absolute -left-12 top-1 text-sm font-bold text-stone-300 tracking-wider">
                        {String(index + 1).padStart(2, "0")}
                      </span>
                      <div class="serif text-base text-stone-700 leading-relaxed contact-markdown">
                        {base.title && (
                          <p class="font-semibold text-stone-900 mb-3">{base.title}</p>
                        )}
                        <p set:html={renderInline(base.text)}></p>
                      </div>
                    </li>
                  ))}
                </ol>
              </div>

              <div class="pt-10 mt-12 border-t border-stone-200">
                <h3 class="text-sm uppercase tracking-[0.3em] text-stone-900 font-bold mb-6">
                  {conditionsHeading}
                </h3>

                <ul class="space-y-4 serif text-base text-stone-700 leading-relaxed">
                  {conditions.map((condition) => (
                    <li class="flex gap-4">
                      <span class="mt-2 w-1.5 h-1.5 bg-stone-400 rounded-full shrink-0"></span>
                      <p class="contact-markdown" set:html={renderInline(condition)}></p>
                    </li>
                  ))}
                </ul>

                {note && (
                  <div class="mt-10 pt-8 border-t border-stone-100">
                    <p
                      class="serif text-base text-stone-700 leading-relaxed italic contact-markdown"
                      set:html={renderInline(note)}
                    ></p>
                  </div>
                )}
              </div>
            </div>
          </div>
        </section>

      </div>
    </main>
  </Layout>
</Shell>

<style>
  .contact-markdown :global(strong) {
    font-weight: 600;
    color: #1c1917;
  }

  .contact-markdown :global(em) {
    font-style: italic;
  }

  .contact-markdown :global(a) {
    display: inline-flex;
    align-items: baseline;
    gap: 0.25rem;
    font-weight: 600;
    color: #1c1917;
    text-decoration-line: underline;
    text-underline-offset: 4px;
    transition: color 150ms ease;
  }

  .contact-markdown :global(a:hover) {
    color: #57534e;
  }

  .contact-markdown :global(code) {
    border-radius: 0.25rem;
    background: #f5f5f4;
    padding: 0.125rem 0.5rem;
    color: #292524;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
      "Courier New", monospace;
    font-size: 0.875em;
  }
</style>
