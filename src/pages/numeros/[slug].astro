---
import Shell from "../../layouts/Shell.astro";
import PostPreview from "../../components/PostPreview.astro";
import { getCollection, getEntry, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const issues: CollectionEntry<"issues">[] = await getCollection("issues");

  return issues.map((issue: CollectionEntry<"issues">) => ({
    params: { slug: issue.id.replace(/\.md$/, '') },
    props: { issue },
  }));
}

const { issue } = Astro.props as { issue: CollectionEntry<"issues"> };

// Load all posts and filter to this issue
const allPosts: CollectionEntry<"posts">[] = await getCollection("posts",
  (p: CollectionEntry<"posts">) => (p.data.status ?? "published") === "published",
);

// Use issue slug (without .md extension) to match posts
const issueSlug = issue.id.replace(/\.md$/, '');

const issuePosts: CollectionEntry<"posts">[] = allPosts
  .filter((post: CollectionEntry<"posts">) => post.data.issue === issueSlug)
  .slice()
  .sort(
    (a: CollectionEntry<"posts">, b: CollectionEntry<"posts">) =>
      b.data.date.valueOf() - a.data.date.valueOf()
  );

// Load authors for each post
const issuePostsWithAuthors: { post: CollectionEntry<"posts">; author: CollectionEntry<"authors"> }[] =
  await Promise.all(
    issuePosts.map(async (post: CollectionEntry<"posts">) => {
      const author = await getEntry(post.data.author);
      if (!author) throw new Error(`Author not found for post: ${post.slug}`);
      return { post, author };
    })
  );

const formatDate = (date: Date, issueSlug?: string): string => {
  // Special case for the first issue (2018-2025)
  if (issueSlug === 'ano-1-numero-0') {
    return '2018–2025';
  }
  return new Intl.DateTimeFormat("es-MX", {
    year: "numeric",
    month: "long",
  }).format(date);
};
---

<Shell title={`${issue.data.title} · El Gallo Galante`} description={issue.data.description}>
  <div class="max-w-6xl mx-auto px-6">
    {/* Issue Header */}
    <header class="max-w-3xl mx-auto mb-16 md:mb-24 text-center">
      {/* Cover Image (optional, large) */}
      {issue.data.coverImage && (
        <div class="mb-10 max-w-xl mx-auto">
          <img
            src={issue.data.coverImage}
            alt={issue.data.title}
            class="w-full h-auto rounded-lg shadow-lg grayscale hover:grayscale-0 transition-all duration-700"
            loading="eager"
          />
        </div>
      )}

      <p class="text-[10px] tracking-[0.3em] uppercase font-bold text-stone-800 bg-stone-100 inline-block px-4 py-1">
        Edición {issue.data.number || ''}
      </p>

      <h1 class="display-serif text-4xl md:text-7xl font-bold leading-tight mt-6">
        {issue.data.title}
      </h1>

      <p class="mt-4 text-sm md:text-base text-stone-500 tracking-wide serif">
        {formatDate(issue.data.date, Astro.params.slug)}
      </p>

      {issue.data.description && (
        <p class="serif text-lg md:text-xl text-stone-600 leading-relaxed max-w-2xl mx-auto mt-6">
          {issue.data.description}
        </p>
      )}

      <div class="mt-10 text-[10px] uppercase tracking-[0.3em] text-stone-400">
        {issuePostsWithAuthors.length} {issuePostsWithAuthors.length === 1 ? 'texto' : 'textos'}
      </div>
    </header>

    {/* Posts Section */}
    {issuePostsWithAuthors.length > 0 ? (
      <section class="space-y-14 md:space-y-20">
        {issuePostsWithAuthors.map(({ post, author }) => (
          <PostPreview
            post={post}
            authorName={author.data.name}
            authorSlug={author.slug}
          />
        ))}
      </section>
    ) : (
      <div class="max-w-2xl mx-auto text-center py-12">
        <p class="serif text-stone-500 italic text-lg">
          Esta edición aún no tiene textos publicados.
        </p>
      </div>
    )}

    {/* Back to Editions Index */}
    <footer class="mt-24 pt-16 border-t border-stone-100 text-center">
      <a
        href="/numeros"
        class="inline-block px-6 py-3 text-xs uppercase tracking-[0.3em] border border-stone-200 hover:border-stone-400 hover:bg-stone-50 transition rounded-full"
      >
        ← Ver todos los números
      </a>
    </footer>
  </div>
</Shell>
