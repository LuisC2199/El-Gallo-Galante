---
const CATEGORIES = [
  { slug: "poesia", label: "Poesía" },
  { slug: "narrativa", label: "Narrativa" },
  { slug: "critica", label: "Crítica" },
  { slug: "ensayo", label: "Ensayo" },
  { slug: "epistolario", label: "Epistolario" },
] as const;

const { pathname } = Astro.url;
const isEdicionesActive = pathname.startsWith('/numeros');
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-[#fcfcfc]/90 backdrop-blur-sm border-b border-stone-100">
  <div class="max-w-6xl mx-auto px-6 h-16 md:h-24 flex items-center justify-between">
    <a href="/" class="flex items-center gap-4 group">
      <img
        src="/assets/logo.png"
        alt="El Gallo Galante"
        class="w-18 h-18 md:w-20 md:h-20 object-cover transition-transform duration-500 group-hover:scale-105"
      />
      <span class="display-serif text-xl md:text-3xl font-bold tracking-tight">
        El Gallo Galante
      </span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex gap-8 items-center text-sm font-light tracking-widest uppercase">
      <a
        href="/numeros"
        class={`relative font-medium transition-colors ${isEdicionesActive ? 'text-stone-800' : 'text-stone-600 hover:text-stone-400'}`}
      >
        Números
        {isEdicionesActive && (
          <span class="absolute -bottom-1 left-0 right-0 h-[1px] bg-stone-800"></span>
        )}
      </a>
      {CATEGORIES.map((c) => (
        <a
          href={`/categoria/${c.slug}`}
          class="hover:text-stone-400 transition-colors"
        >
          {c.label}
        </a>
      ))}
      <a
        href="/contacto"
        class="px-3 py-1 bg-stone-100 text-[10px] rounded hover:bg-stone-200 transition-colors"
      >
        Contáctanos
      </a>
    </div>

    <!-- Mobile toggle (CSS-only) -->
    <label class="md:hidden text-stone-800 cursor-pointer relative z-[60]">
      <input id="nav-toggle" type="checkbox" class="hidden peer" />
      <span class="text-xs uppercase tracking-widest peer-checked:hidden">Menú</span>
      <span class="text-xs uppercase tracking-widest hidden peer-checked:inline">Cerrar</span>

      <!-- Mobile Menu Backdrop -->
      <div class="hidden peer-checked:block fixed inset-0 bg-black/30 z-[55] backdrop-blur-sm mobile-menu-backdrop"></div>

      <!-- Mobile Menu Panel -->
      <div class="fixed top-0 right-0 h-screen w-[80vw] max-w-sm bg-white/95 backdrop-blur-md shadow-2xl z-[56] transform translate-x-full peer-checked:translate-x-0 transition-transform duration-300 ease-in-out overflow-y-auto mobile-menu-panel">
        <div class="flex flex-col gap-8 items-start pt-24 px-8 pb-8 min-h-screen">
          <a
            href="/numeros"
            class={`display-serif text-3xl font-semibold ${isEdicionesActive ? 'text-stone-900' : 'text-stone-700'} hover:text-stone-900 transition-colors`}
          >
            Números
          </a>
          {CATEGORIES.map((c) => (
            <a
              href={`/categoria/${c.slug}`}
              class="display-serif text-3xl font-medium text-stone-800 hover:text-stone-900 transition-colors"
            >
              {c.label}
            </a>
          ))}
          <a
            href="/contacto"
            class="text-stone-400 text-sm tracking-widest uppercase mt-4 hover:text-stone-600 transition-colors"
          >
            Contáctanos
          </a>
        </div>
      </div>
    </label>
  </div>
</nav>
<style>
  .mobile-menu-backdrop {
    animation: fadeIn 0.3s ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>