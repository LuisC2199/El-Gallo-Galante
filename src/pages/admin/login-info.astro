---
export const prerender = false;
import "../../styles/global.css";

type Reason = "missing-access-jwt" | "invalid-access-jwt" | "unauthorized" | "unknown";

const reason = (Astro.url.searchParams.get("reason") ?? "unknown") as Reason;

const messages: Record<Reason, { heading: string; body: string; hint: string }> = {
  "missing-access-jwt": {
    heading: "Sesión no iniciada",
    body: "No se encontró una sesión de Cloudflare Access válida. Para acceder al panel, debes iniciar sesión con tu cuenta de Google a través de Cloudflare Access.",
    hint: "Al hacer clic en el botón de abajo, Cloudflare Access debería solicitarte que inicies sesión con Google. Si el botón te regresa aquí sin mostrar una pantalla de inicio de sesión, hay un problema de configuración en Cloudflare Access — contacta al administrador.",
  },
  "invalid-access-jwt": {
    heading: "Sesión inválida o expirada",
    body: "Tu sesión de Cloudflare Access expiró o no pudo verificarse. Intenta acceder de nuevo para renovar tu sesión.",
    hint: "Si el problema persiste después de iniciar sesión nuevamente, es posible que tu cuenta no esté en la lista de editores autorizados.",
  },
  "unauthorized": {
    heading: "Sin permiso de acceso",
    body: "Tu identidad fue verificada, pero tu cuenta no tiene permisos para acceder al panel de administración.",
    hint: "Solicita al administrador del sitio que agregue tu correo a la política de acceso en Cloudflare Zero Trust.",
  },
  "unknown": {
    heading: "Acceso requerido",
    body: "El panel de administración está protegido. Para acceder, inicia sesión con tu cuenta de Google a través de Cloudflare Access.",
    hint: "Si el problema persiste, contacta al administrador del sitio.",
  },
};

const msg = messages[reason] ?? messages["unknown"];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Acceso requerido · El Gallo Galante</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="m-0 font-sans bg-stone-50 text-stone-800 flex items-center justify-center min-h-screen"
  >
    <div
      class="max-w-md w-full mx-auto p-8 bg-white rounded-xl shadow-sm border border-stone-200 text-center"
    >
      <h1 class="text-lg font-semibold tracking-tight mb-1">
        El Gallo Galante
        <span class="text-xs font-normal text-stone-400 ml-1">admin</span>
      </h1>

      <div class="my-6 h-px bg-stone-100"></div>

      <h2 class="text-base font-medium mb-3 text-stone-700">
        {msg.heading}
      </h2>

      <p class="text-sm text-stone-500 leading-relaxed mb-4">
        {msg.body}
      </p>

      <p class="text-sm text-stone-400 leading-relaxed mb-6 italic text-xs">
        {msg.hint}
      </p>

      {reason !== "unauthorized" && (
        <a
          href="/admin"
          class="inline-block px-5 py-2 text-sm font-medium text-white bg-stone-800 rounded-lg hover:bg-stone-700 transition-colors"
        >
          Iniciar sesión con Google
        </a>
      )}

      {reason === "unauthorized" && (
        <p class="inline-block px-5 py-2 text-sm font-medium text-stone-400 bg-stone-100 rounded-lg cursor-not-allowed">
          Acceso denegado
        </p>
      )}

      <p class="mt-6 text-xs text-stone-400">
        ¿Necesitas acceso? Contacta al administrador del sitio.
      </p>
    </div>
  </body>
</html>
